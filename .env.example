# LLM endpoint (any OpenAI-compatible API: Ollama, LiteLLM, vLLM, OpenAI, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=http://localhost:11434/v1

# Model name as known to your LLM endpoint
LLM_MODEL=llama3

# Agent identity
AGENT_NAME=a2a-agent
AGENT_PORT=8000

# Langfuse tracing (optional — agent works without it)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
